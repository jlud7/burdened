# Copy this file to `.env` and fill in your Replicate API token
# (from https://replicate.com/account/api-tokens — starts with r8_)
REPLICATE_API_TOKEN=

# Optional: override the image model slug if Replicate names it differently
# REPLICATE_MODEL=openai/gpt-image-2
# Optional: extra JSON merged into the model input, e.g. {"quality":"high"}
# REPLICATE_EXTRA_INPUT=
